# Database
DATABASE_URL=postgresql+asyncpg://polymarket:polymarket@localhost:5433/polymarket_bot

# Anthropic API (for AI analysis with web search)
ANTHROPIC_API_KEY=sk-ant-...

# Detection thresholds
MIN_TRADE_USD=10000
MIN_SCORE_TO_TRADE=5
MAX_AI_CALLS_PER_DAY=50

# Paper trading
INITIAL_BALANCE=10000
MAX_POSITION_PCT=20
MAX_POSITIONS=10
STOP_LOSS_PCT_HIGH=30
STOP_LOSS_PCT_LOW=50
TAKE_PROFIT_PCT=80
TRAILING_STOP_TRIGGER_PCT=40
CIRCUIT_BREAKER_PCT=5
CATEGORY_CONCENTRATION_MAX_PCT=40

# Polymarket endpoints
CLOB_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
GAMMA_API_URL=https://gamma-api.polymarket.com
CLOB_API_URL=https://clob.polymarket.com
DATA_API_URL=https://data-api.polymarket.com

# Logging
LOG_LEVEL=INFO
